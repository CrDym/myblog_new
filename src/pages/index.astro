---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="My Blog" description="A minimal blog">
  <section class="hero">
    <div class="hero-avatar"></div>
    <h1 class="hero-title">你好，我是 CrDym</h1>
    <p class="hero-desc">热爱技术与分享，记录学习心得与生活感悟。</p>
    <div class="hero-links">
      <a href="https://github.com/CrDym" target="_blank" rel="noopener">GitHub</a>
      <span class="separator">·</span>
      <a href="mailto:your@email.com">Email</a>
    </div>
  </section>
  <h2 class="section-title">最新文章</h2>
  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        {post.data.cover && (
          <a href={`/posts/${post.slug}`} class="post-cover-link">
            <img src={post.data.cover} alt={post.data.title} class="post-cover" loading="lazy" />
          </a>
        )}
        <h2 class="post-title">
          <a href={`/posts/${post.slug}`}>{post.data.title}</a>
        </h2>
        <div class="post-meta">
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
        {post.data.description && <p class="post-description">{post.data.description}</p>}
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <a href={`/tags/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>
</BaseLayout>
